generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String?
  name             String?
  avatar           String?
  role             String             @default("USER")
  emailVerified    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  continueWatching ContinueWatching[]
  favorites        Favorite[]
  notifications    Notification[]
  profiles         Profile[]
  ratings          Rating[]
  reviews          Review[]
  subscriptions    Subscription[]
  watchHistory     WatchHistory[]
  watchlist        Watchlist[]

  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String
  name      String
  avatar    String?
  isKids    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?            @unique
  status               String             @default("INACTIVE")
  plan                 String             @default("FREE")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  billingRecords       BillingRecord[]
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model BillingRecord {
  id              String       @id @default(cuid())
  subscriptionId  String
  stripePaymentId String?      @unique
  amount          Float
  currency        String       @default("USD")
  status          String
  description     String?
  createdAt       DateTime     @default(now())
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("billing_records")
}

model Movie {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  description      String
  synopsis         String?
  releaseYear      Int
  duration         Int
  rating           String?
  posterUrl        String?
  backdropUrl      String?
  trailerUrl       String?
  videoUrl         String?
  isPremium        Boolean            @default(false)
  isPublished      Boolean            @default(false)
  publishDate      DateTime?
  viewCount        Int                @default(0)
  averageRating    Float              @default(0)
  language         String?
  country          String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isAIProcessed    Boolean            @default(false)
  highlights       Highlight[]
  cast             CastMember[]
  continueWatching ContinueWatching[]
  crew             CrewMember[]
  favorites        Favorite[]
  ratings          Rating[]
  reviews          Review[]
  subtitles        Subtitle[]
  videoAssets      VideoAsset[]
  watchHistory     WatchHistory[]
  watchlist        Watchlist[]
  genres           Genre[]            @relation("GenreToMovie")
  tags             Tag[]              @relation("MovieToTag")

  @@map("movies")
}

model Series {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  description      String
  synopsis         String?
  startYear        Int
  endYear          Int?
  rating           String?
  posterUrl        String?
  backdropUrl      String?
  trailerUrl       String?
  isPremium        Boolean            @default(false)
  isPublished      Boolean            @default(false)
  totalSeasons     Int                @default(0)
  totalEpisodes    Int                @default(0)
  viewCount        Int                @default(0)
  averageRating    Float              @default(0)
  language         String?
  country          String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  cast             CastMember[]
  continueWatching ContinueWatching[]
  crew             CrewMember[]
  favorites        Favorite[]
  ratings          Rating[]
  reviews          Review[]
  seasons          Season[]
  watchlist        Watchlist[]
  genres           Genre[]            @relation("GenreToSeries")
  tags             Tag[]              @relation("SeriesToTag")

  @@map("series")
}

model Season {
  id           String    @id @default(cuid())
  seriesId     String
  seasonNumber Int
  title        String?
  description  String?
  posterUrl    String?
  releaseDate  DateTime?
  episodeCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  episodes     Episode[]
  series       Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, seasonNumber])
  @@map("seasons")
}

model Episode {
  id               String             @id @default(cuid())
  seasonId         String
  episodeNumber    Int
  title            String
  description      String
  duration         Int
  releaseDate      DateTime?
  thumbnailUrl     String?
  videoUrl         String?
  viewCount        Int                @default(0)
  averageRating    Float              @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  continueWatching ContinueWatching[]
  ratings          Rating[]
  reviews          Review[]
  subtitles        Subtitle[]
  videoAssets      VideoAsset[]
  watchHistory     WatchHistory[]
  season           Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, episodeNumber])
  @@map("episodes")
}

model Highlight {
  id          String   @id @default(cuid())
  movieId     String
  title       String
  timestamp   Int
  description String?
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  movie       Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("highlights")
}

model Subtitle {
  id        String   @id @default(cuid())
  movieId   String?
  episodeId String?
  language  String
  label     String
  url       String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("subtitles")
}

model VideoAsset {
  id        String   @id @default(cuid())
  movieId   String?
  episodeId String?
  quality   String
  url       String
  size      Int?
  format    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@map("video_assets")
}

model Genre {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movies    Movie[]  @relation("GenreToMovie")
  series    Series[] @relation("GenreToSeries")

  @@map("genres")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movies    Movie[]  @relation("MovieToTag")
  series    Series[] @relation("SeriesToTag")

  @@map("tags")
}

model CastMember {
  id        String   @id @default(cuid())
  movieId   String?
  seriesId  String?
  name      String
  character String?
  role      String?
  order     Int      @default(0)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("cast_members")
}

model CrewMember {
  id        String   @id @default(cuid())
  movieId   String?
  seriesId  String?
  name      String
  job       String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@map("crew_members")
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  seriesId  String?
  episodeId String?
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
  @@unique([userId, episodeId])
  @@map("ratings")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  seriesId  String?
  episodeId String?
  content   String
  rating    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  seriesId  String?
  createdAt DateTime @default(now())
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
  @@map("favorites")
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  seriesId  String?
  createdAt DateTime @default(now())
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
  @@map("watchlist")
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  episodeId String?
  progress  Int
  duration  Int
  completed Boolean  @default(false)
  watchedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("watch_history")
}

model ContinueWatching {
  id        String   @id @default(cuid())
  userId    String
  movieId   String?
  seriesId  String?
  episodeId String?
  progress  Int
  duration  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  movie     Movie?   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  series    Series?  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@unique([userId, seriesId])
  @@unique([userId, episodeId])
  @@map("continue_watching")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SystemStatus {
  id            String   @id @default("current")
  isUpdating    Boolean  @default(false)
  progress      Int      @default(0) // 0-100
  estimatedTime String?  // e.g. "5 minut"
  message       String?  @default("Všechny systémy jsou v pořádku")
  updatedAt     DateTime @updatedAt

  @@map("system_status")
}

model UpdateLog {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("info") // info, success, warning, error
  timestamp DateTime @default(now())

  @@map("update_logs")
}
