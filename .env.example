# Database Configuration (SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# Admin Bootstrap (Seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="3Play"
NODE_ENV=development

# System Status & Updates
UPDATE_SECRET=your-secure-update-token
APP_URL=your-app-domain.com

# AI Configuration
OPENAI_API_KEY=your-openai-api-key

# MultCloud WebDAV Storage
WEBDAV_BASE_URL=https://your-multcloud-webdav-endpoint.example.com/dav
WEBDAV_USERNAME=your-webdav-username
WEBDAV_PASSWORD=your-webdav-password

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:3000/api
