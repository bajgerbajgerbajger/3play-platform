# Database Configuration (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="3Play"
NODE_ENV=development

# System Status & Updates
UPDATE_SECRET=your-secure-update-token
APP_URL=your-app-domain.com

# AI Configuration
OPENAI_API_KEY=your-openai-api-key

# MultCloud (WebDAV) Storage (optional)
MULTCLOUD_WEBDAV_URL=
MULTCLOUD_WEBDAV_USER=
MULTCLOUD_WEBDAV_PASSWORD=
MULTCLOUD_PUBLIC_BASE_URL=
MULTCLOUD_REMOTE_DIR=uploads
MULTCLOUD_KEEP_LOCAL=true
